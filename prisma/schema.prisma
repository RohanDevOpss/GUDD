// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String     @id @default(cuid())
  email         String     @unique
  emailVerified DateTime?
  name          String?
  image         String?
  password      String?
  phone         String?
  role          Role       @default(CUSTOMER)
  
  // Relations
  accounts      Account[]
  sessions      Session[]
  orders        Order[]
  addresses     Address[]
  rewards       RewardTransaction[]
  referrals     Referral[]
  referredBy    Referral[]        @relation("referrer")
  
  // Metadata
  totalSpent    Float     @default(0)
  totalOrders   Int       @default(0)
  joinedAt      DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([email])
  @@index([role])
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

enum Role {
  CUSTOMER
  ADMIN
  FRANCHISE_OWNER
}

model Product {
  id          String   @id @default(cuid())
  name        String
  description String?
  price       Float
  image       String?
  category    String
  isAvailable Boolean  @default(true)
  
  // Relations
  orderItems  OrderItem[]
  inventory   Inventory[]
  
  // Metadata
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category])
  @@index([isAvailable])
}

model Order {
  id              String   @id @default(cuid())
  userId          String
  status          OrderStatus @default(PENDING)
  totalAmount     Float
  coinsUsed       Int       @default(0)
  
  // Address
  deliveryAddress String
  latitude        Float?
  longitude       Float?
  
  // Payment
  paymentMethod   PaymentMethod
  paymentStatus   PaymentStatus @default(PENDING)
  razorpayOrderId String?
  
  // Relations
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  items           OrderItem[]
  
  // EV Assignment
  assignedEVId    String?
  assignedEV      EVVehicle? @relation(fields: [assignedEVId], references: [id])
  
  // Estimated delivery
  estimatedDeliveryTime DateTime?
  actualDeliveryTime    DateTime?
  
  // Metadata
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@index([paymentStatus])
  @@index([createdAt])
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  productId String
  quantity  Int
  price     Float
  
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@index([productId])
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PREPARING
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
  FAILED
}

enum PaymentMethod {
  RAZORPAY
  UPI
  COD
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

model Address {
  id        String  @id @default(cuid())
  userId    String
  label     String  @default("Home")
  address   String
  city      String
  state     String
  pincode   String
  latitude  Float
  longitude Float
  isDefault Boolean @default(false)
  
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([isDefault])
}

model RewardTransaction {
  id        String   @id @default(cuid())
  userId    String
  amount    Int
  type      RewardType
  reference String?
  
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([type])
}

enum RewardType {
  PURCHASE
  REFERRAL_GIVEN
  REFERRAL_RECEIVED
  REDEMPTION
}

model Referral {
  id            String   @id @default(cuid())
  referrerId    String
  referredUserId String
  status        ReferralStatus @default(PENDING)
  
  referrer      User     @relation(fields: [referrerId], references: [id], onDelete: Cascade)
  referredUser  User     @relation("referrer", fields: [referredUserId], references: [id], onDelete: Cascade)
  
  createdAt     DateTime @default(now())
  completedAt   DateTime?

  @@unique([referrerId, referredUserId])
  @@index([referrerId])
  @@index([status])
}

enum ReferralStatus {
  PENDING
  COMPLETED
  EXPIRED
}

model EVVehicle {
  id              String   @id @default(cuid())
  vehicleNumber   String   @unique
  riderName       String
  riderPhone      String
  status          EVStatus @default(AVAILABLE)
  latitude        Float?
  longitude       Float?
  currentCapacity Float    @default(100)
  maxCapacity     Float    @default(100)
  
  // Relations
  orders          Order[]
  inventory       Inventory[]
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([status])
}

enum EVStatus {
  AVAILABLE
  ON_DELIVERY
  MAINTENANCE
  OFFLINE
}

model Inventory {
  id        String   @id @default(cuid())
  evId      String
  productId String
  quantity  Int      @default(0)
  
  ev        EVVehicle @relation(fields: [evId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  
  updatedAt DateTime @updatedAt

  @@unique([evId, productId])
  @@index([evId])
  @@index([productId])
}

model FranchiseApplication {
  id            String   @id @default(cuid())
  name          String
  email         String
  phone         String
  city          String
  location      String
  experience    String?
  investment    Float?
  status        ApplicationStatus @default(PENDING)
  notes         String?
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([status])
  @@index([createdAt])
}

enum ApplicationStatus {
  PENDING
  REVIEWING
  APPROVED
  REJECTED
}

model ContactSubmission {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String
  message   String
  status    ContactStatus @default(NEW)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([createdAt])
}

enum ContactStatus {
  NEW
  RESPONDED
  RESOLVED
}
